Private Sub Aceptar_Click()
    'Comprobar que no haya cuadros hojas sin asignar a ninguna de las tres listas
    If ListaHojasM.ListCount > 0 Then
        vbOut = MsgBox("Quedan hojas sin clasificar. Se pasarán automáticamente a la lista de ignorar. Continuar?", vbYesNoCancel + vbExclamation, "Hojas sin clasificar")
        Select Case vbOut
            Case 6  'Si
                'Pasar a diccionario de ignorar con valor vacío
                For i = 0 To ListaHojasM.ListCount - 1
                    ListaHojasM.ListIndex = 0   'Siempre la primera posición porque se van eliminando al pasarlas a la lista de ignorar
                    Call Clasificar("Ignorar")
                Next i
            Case 7  'No
                Exit Sub
            Case Else
                Exit Sub
        End Select
    End If
    'Comprobar que no hay cuadros sin propiedades asignadas
    j = 0
    For i = 0 To ListaCuadros.ListCount - 1
        'Pasar a diccionario de cuadros con valores vacíos
        If Not cuadrosProv.Exists(ListaCuadros.List(i)) Then 
            cuadrosProv.Add ListaCuadros.List(i), Array("", "", "")
        End If

        If ListaCuadros.List(i, 1) = "X" Then
        Else
            j = j + 1
        End If
    Next i

    If j > 0 Then
        vbOut = MsgBox("Hay " & j & " cuadros sin propiedades asignadas. Continuar de todas formas?", vbYesNoCancel + vbExclamation, "Cuadro sin propiedades")
        Select Case vbOut
            Case 6  'Si

            Case 7  'No
                Exit Sub
            Case Else
                Exit Sub
        End Select
    End If

    'Comprobar nombres de cuadros y resultados
    Set NoCmpt = New Collection
    Set cambios = CreateObject("Scripting.Dictionary")

    'Llenar colección con nombres de hojas
    For i = 0 To ListaCuadros.ListCount - 1
        'Comprobar formato correcto de nombres de hojas
        If InStr(ListaCuadros.List(i), " ") > 0 Then    'El nombre contiene espacios, no es correcto
            NoCmpt.Add ListaCuadros.List(i)
        Else
            Hoja.Sheets("Busquedas").Range("A1").Formula = "=" & ListaCuadros.List(i) & "!A1"
            DoEvents
            'MsgBox "Poniendo fórmula: " & Hoja.Sheets("Busquedas").Range("A1").Formula
            If InStr(Hoja.Sheets("Busquedas").Range("A1").Formula, "'") > 0 Then    'La formula contiene comillas, por lo que el nombre no es correcto
                NoCmpt.Add ListaCuadros.List(i)
                'MSgBox ListaCuadros.List(i)
            End If
            Hoja.Sheets("Busquedas").Range("A1").Formula = ""
        End If
    Next i

    'Limpiar celda de prueba
    Hoja.Sheets("Busquedas").Range("A1").Formula = ""

    If NoCmpt.count > 0 Then
        salirMacr = False
        MsgBox "Hay " & NoCmpt.count & " hojas con nombres incompatibles. Se abrirá un formulario para corregirlos", vbExclamation, "Nombres incompatibles"
        ufCorregirInv.Show vbModeless 'Mostrar formulario de corrección de incompatibles modal para forzar a usuario a corregir incompatibles antes de continuar

        Do While Not ContinuarEjecucion
            DoEvents
        Loop

        If salirMacr Then
            Exit Sub
        End If

        Dim Nombre As Variant
        'Realizar cambios de nombres en hojas
        For Each Nombre In cambios.Keys
            MsgBox "Renombrando hoja " & Nombre & " a " & cambios(Nombre)
            Hoja.Sheets(Nombre).name = cambios(Nombre) 'Renombrar hojas según cambios realizados en formulario de corrección de incompatibles
            For i = 0 To ListaCuadros.ListCount - 1 'Actualizar nombres en lista de cuadros
                If ListaCuadros.List(i) = Nombre Then
                    ListaCuadros.List(i) = cambios(Nombre) 'Actualizar nombre en lista de cuadros
                End If
            Next i
            If cuadrosProv.Exists(Nombre) Then 'Actualizar claves en diccionario de cuadros provisionales
                cuadrosProv.Add cambios(Nombre), cuadrosProv(Nombre) 'Añadir nuevo nombre con mismo valor que el antiguo
                cuadrosProv.Remove Nombre 'Eliminar antiguo nombre del diccionario de cuadros provisionales
            End If
        Next Nombre
    End If

    'Pasar listas a diccionario público y cerrar
    Call Clasificar("Cuadro", "Diccionario")
    Call Clasificar("Resultado", "Diccionario")
    Call Clasificar("Ignorar", "Diccionario")

    Cerrar = True
    Unload Me
End Sub

Function ExistePagina(nombrePag As String, Optional wb As Workbook) As Boolean
    Dim test As Worksheet
    If wb Is Nothing Then
        Set wb = ThisWorkbook 'Usar el libro actual
    End If
    On Error GoTo ErrorHandler
    Set test = wb.Sheets(nombrePag)
    ExistePagina = True
    Exit Function
ErrorHandler:
    'Ha ocurrido un error al abrir la pagina, no existe
    ExistePagina = False
End Function