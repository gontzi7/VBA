Private Sub BuscarAutomatico_Click()
    MsgBox "En desarrollo", vbInformation, "Función no disponible"

    If ListaCuadros.ListCount = 0 Then
        MsgBox "No ha categorizado ningún cuadro, rellene todos los cuadros antes de continuar.", vbInformation, "Error"
        Exit Sub
    End If

    vbOut = MsgBox("Rellenar automáticamente las líneas de alimentación de todos los cuadros?", vbYesNoCancel + vbQuestion, "Confirmar operación")
    Select Case vbOut
        Case 6  'Si, todos automático
            Call RellenarAutomatico(True)
        Case 7  'No, sólo uno automático
            If ListaCuadros.ListIndex = -1 Then
                MsgBox "No ha seleccionado ningún cuadro", vbInformation, "Error"
                Exit Sub
            End If
            Call RellenarAutomatico()
        Case Else   'Cancelar
    End Select
End Sub

Private Sub RellenarAutomatico(Optional todos As Boolean = False)
    Dim inicio As Long

    If todos Then
        inicio = 0
    Else
        inicio = ListaCuadros.ListIndex
    End If

    Dim valores As Range
    Dim lineasCuadros() As Variant
    Dim filasAlim() As Variant
    Dim resultados As Worksheet

    If ListaResultados.ListIndex = -1 Then
        If ExistePagina("TABLA DE RESULTADOS", Hoja) Then
            Set resultados = Hoja.Sheets("TABLA DE RESULTADOS")
        Else
            MsgBox "Elegir una hoja de resultados primero", vbCritical, "Error"
            Exit Sub
        End If
    Else
        Set resultados = Hoja.Sheets(ListaResultados.List(0))
    End If

    'Guardar tabla en array para agilizar búsquedas
    Set valores = resultados.Columns("A:A")
    lineasCuadros = valores.Formula

    Set valores = resultados.Columns("AF:AF")
    filasAlim = valores.Value

    For i = inicio To ListaCuadros.ListCount - 1
        ListaCuadros.ListIndex = i  'Seleccionar cuadro

        'Buscar cuadro en fórmulas de lineas
        For j = 1 To UBound(lineasCuadros)
            If InStr(lineasCuadros(j, 1), ListaCuadros.List(i)) > 0 Then
                'MsgBox "Encontrado cuadro " & ListaCuadros.List(i) & " formula " & lineasCuadros(j, 1) & " fila " & j & " fila alim " & filasAlim(j, 1)
                'Definir rango de la línea de alimentación
                Set Rango = resultados.Range("A" & filasAlim(j, 1) & ":B" & filasAlim(j, 1))
                'MsgBox "Rango definido: " & Rango.Address
                Exit For
            End If
        Next j

        If filasAlim(filasAlim(j, 1), 1) = 9 Then 'Si la línea de alimentación un paso hacia atrás se alimenta de CT (9) marcar como externo
            AlimExterno.Value = True
        Else
            AlimExterno.Value = False
        End If

        'MsgBox "Externo: " & AlimExterno.Value & " Fila alimentación: " & filasAlim(j, 1)

        NombreLinCuad.Value = Rango.Cells(1, 2).Value 'Nombre del cuadro
        NombreTagCuad.Value = Rango.Cells(1, 1).Value 'Tag del cuadro
        Call AplicarProp_Click 'Aplicar propiedades al cuadro
        If Not todos Then Exit For 'Si no es todos, salir después del primer ciclo
    Next i
End Sub

Private Sub ElegirEnHoja_Click()    'Al pulsar botón, dejar a usuario seleccionar celdas que contengan nombre y tag de cuadro, y añadir a diccionario de cuadros provisionales
    If ListaCuadros.ListIndex = -1 Then
        MsgBox "No ha seleccionado ningún cuadro", vbInformation, "Error"
        Exit Sub
    End If    
    Me.Hide

    On Error Resume Next
    Set Rango = Application.InputBox("Seleccione el rango de celdas que contienen el nombre y el tag del cuadro. El primer valor del rango se considerará el tag," _
        " y el segundo el nombre", Title:= "Alimentación de " & ListaCuadros.List(ListaCuadros.ListIndex), Type:=8)

    Me.Show vbModeless
    If Rango Is Nothing Then
        MsgBox "No ha seleccionado ningún rango", vbInformation, "Error"
        Exit Sub
    End If
    On Error GoTo 0

    NombreLinCuad.Value = Rango.Cells(1, 2).Value 'Nombre del cuadro
    NombreTagCuad.Value = Rango.Cells(1, 1).Value 'Tag del cuadro
End Sub

Private Sub ListaCuadros_Change()   'Al seleccionar un cuadro, mostrar sus propiedades en el formulario
    If ListaCuadros.ListIndex = -1 Then
        SeccionCuad.Caption = "Propiedades de cuadro"
        NombreLinCuad.Value = ""
        NombreTagCuad.Value = ""
        AlimExterno.Value = False
        Exit Sub
    End If

    If ListaCuadros.ListIndex > -1 Then
        SeccionCuad.Caption = "Propiedades de cuadro " & ListaCuadros.List(ListaCuadros.ListIndex)
    End If

    If cuadrosProv.Exists(ListaCuadros.List(ListaCuadros.ListIndex)) Then
        SeccionCuad.Caption = "Propiedades de cuadro " & ListaCuadros.List(ListaCuadros.ListIndex)
        If cuadrosProv(ListaCuadros.List(ListaCuadros.ListIndex))(0) = "EXTERNO ------>" Then
            AlimExterno.Value = True
        Else
            AlimExterno.Value = False
        End If
        NombreLinCuad.Value = cuadrosProv(ListaCuadros.List(ListaCuadros.ListIndex))(1)
        NombreTagCuad.Value = cuadrosProv(ListaCuadros.List(ListaCuadros.ListIndex))(2)
    Else
        NombreLinCuad.Value = ""
        NombreTagCuad.Value = ""
    End If
End Sub

Private Sub AplicarProp_Click()
    If AlimExterno Then
        atributos(0) = "EXTERNO ------>"
    Else
        atributos(0) = "I"
    End If
    atributos(1) = NombreLinCuad.Value
    atributos(2) = NombreTagCuad.Value

    'Introducir en diccionario de cuadros provisionales
    If cuadrosProv.Exists(ListaCuadros.List(ListaCuadros.ListIndex)) Then
        cuadrosProv.Remove ListaCuadros.List(ListaCuadros.ListIndex) 'Eliminar del diccionario de cuadros provisionales para actualizar con nuevos valores
    End If
    cuadrosProv.Add ListaCuadros.List(ListaCuadros.ListIndex), atributos()
    'Marcar en segunda columna de la lista que tiene propiedades asignadas
    ListaCuadros.List(ListaCuadros.ListIndex, 1) = "X"
End Sub

Private Sub LimpiarProp_Click()
    If cuadrosProv.Exists(ListaCuadros.List(ListaCuadros.ListIndex)) Then
        cuadrosProv.Remove ListaCuadros.List(ListaCuadros.ListIndex) 'Eliminar del diccionario de cuadros provisionales
        ListaCuadros.List(ListaCuadros.ListIndex, 1) = "" 'Limpiar segunda columna de la lista
        AlimExterno.Value = False
    Else
        NombreLinCuad.Value = ""
        NombreTagCuad.Value = ""
    End If
End Sub

