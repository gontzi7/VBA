Function Escritorio() As String
'returns the path to Desktop
    Escritorio = CreateObject("wscript.shell").specialfolders("desktop")
End Function

Sub CopyToClipboard(ByVal textToCopy As String)
    Dim dataObj As New MSForms.DataObject
    dataObj.SetText textToCopy
    dataObj.PutInClipboard
End Sub

Function GetRangeRowCount(sheetName As String, rngAddress As String, Optional wb As Workbook) As Long

    If wb Is Nothing Then
        Set wb = ThisWorkbook 'Usar el libro actual
    End If

    Dim ws As Worksheet
    Set ws = wb.Sheets(sheetName)
    
    GetRangeRowCount = ws.Range(rngAddress).rows.Count

End Function

