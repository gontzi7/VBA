Option Explicit

Dim i As Long, realizados As Long
Dim corregidos As Boolean
Dim OutPut As Integer
Dim nombreRango As String

Private Sub Cambiar_Click()
    realizados = realizados + 1
    'Guardar en diccionario
    cambios.Add Nombre.Caption, Cambio.Text
    'Añadir contador
    Faltan.Caption = realizados & "/" & NoCmpt.count
    'Borrar de lista
    ListaIncompatibles.RemoveItem ListaIncompatibles.ListIndex
    Call Limpiar_Click
    'Mirar si falta alguno
    If realizados = NoCmpt.count Then
        corregidos = True
        MsgBox "Todas las incompatibilidades corregidas. Pulsa aceptar para continuar.", vbInformation, "Corregido"
        Application.ScreenUpdating = False
        Call Salir_Click
        Exit Sub
    End If
    'Seleccionar siguiente
    If ListaIncompatibles.ListIndex = -1 And ListaIncompatibles.ListCount > 0 Then
        ListaIncompatibles.ListIndex = 0
        Nombre.Caption = ListaIncompatibles.List(ListaIncompatibles.ListIndex)
        Cambio.Enabled = True
        Cambio.SetFocus
    End If
End Sub

Private Sub Cambio_Change()
    Cambiar.Enabled = False
End Sub

Private Sub Comprobar_Click()
    If Cambio.Text = "" Then
        MsgBox "Escribe un nombre para reemplazar", vbExclamation
    Else
        'Comprobar si es válido
        nombreRango = Cambio.Text

        Application.ScreenUpdating = False

        If ExistePagina(nombreRango, Libro) Then   'Comprobar que la página no existe
            MsgBox "El nombre elegido ya existe como página, elige otro.", vbCritical, "Error"
            Exit Sub
        End If
        
        On Error GoTo ErrorHandler

        If ExisteRango(nombreRango, Libro) Then
            'Es válido
            Valido.Caption = "Válido"
            Cambiar.Enabled = True
            Cambiar.SetFocus
        Else
            ' MsgBox "No es válido", vbCritical, "Error"
            Valido.Caption = "No válido"
            Cambiar.Enabled = False
            Cambio.Text = ""
            Cambio.SetFocus
        End If
    
        Application.ScreenUpdating = True
    End If

    Exit Sub
ErrorHandler:
    MsgBox "Ha ocurrido un error al comprobar el nombre: " & Err.Description, vbExclamation, "Error 1010"
End Sub

Private Sub Limpiar_Click()
    'Nombre
    Nombre.Caption = "Elige uno de la lista"
    'Selección
    ListaIncompatibles.ListIndex = -1
    'Campos
    Cambio.Text = ""
    Cambiar.Enabled = False
    Cambio.Enabled = False
    Valido.Caption = " "
End Sub

Private Sub ListaIncompatibles_Click()
    'Al elegir un elemento, añadir a estudio
    If ListaIncompatibles.ListIndex <> -1 Then
        Nombre.Caption = ListaIncompatibles.List(ListaIncompatibles.ListIndex)
        'Campos
        Cambio.Enabled = True
    End If
End Sub

Private Sub Salir_Click()
    Unload Me
End Sub

Private Sub UserForm_Initialize()
    'On Error Resume Next
    'Poner en medio de la pantalla
    With Me
        .StartUpPosition = 0
        .Left = Application.Left + (0.5 * Application.Width) - (0.5 * .Width)
        .Top = Application.Top + (0.5 * Application.Height) - (0.5 * .Height)
        .Show
    End With
    'Marcador
    corregidos = False
    valido.Caption = " "
    'Cargar lista para poder seleccionar

    For i = 1 To NoCmpt.count
        ListaIncompatibles.AddItem NoCmpt(i)
    Next i
    'Contador
    realizados = 0
    Faltan.Caption = realizados & "/" & NoCmpt.count
    'Campos
    Cambiar.Enabled = False
    Cambio.Enabled = False
End Sub

Private Sub UserForm_QueryClose(Cancel As Integer, CloseMode As Integer)
    If Not corregidos Then
        OutPut = MsgBox("No se han corregido todas las ocurrencias." & vbCrLf & _
            "Si sale se detendrá el programa. Salir?", vbExclamation + vbYesNoCancel, "Faltan nombres por corregir")
        Select Case OutPut
            Case 6  'Si
                salirMacr = True
                ContinuarEjecucion = True
            Case 7  'No
                Cancel = 1
            Case 2  'Cancelar
                Cancel = 1
            Case Else   'Otro
                Cancel = 1
        End Select
    Else
        ContinuarEjecucion = True
        salirMacr = False
    End If
End Sub

Function ExisteRango(nom As String, Optional wb As Workbook) As Boolean
    On Error GoTo ErrorHandler

    Dim pag As Worksheet

    Application.ScreenUpdating = False

    'Comprueba si existe un nombre de rango en el libro
    If wb Is Nothing Then
        Set wb = ThisWorkbook 'Usar el libro actual
    End If

    If Not ExistePagina(nom, Libro) Then   'Crear página de prueba para comprobar si el nombre es válido, si no existe
        Set pag = Libro.Sheets.Add
        pag.name = nom
    End If

    wb.Sheets("Busquedas").Range("A2").formula = "=" & nom & "!A1"
    If InStr(wb.Sheets("Busquedas").Range("A2").formula, "'") > 0 Then    'La formula contiene comillas, por lo que el nombre no es correcto
        ExisteRango = False
    Else
        ExisteRango = True
    End If
    'Limpieza
    Application.DisplayAlerts = False
    pag.Delete 'Borrar página de prueba
    Libro.Sheets("Busquedas").Range("A2").formula = ""  'Limpiar fórmula de prueba
    Application.DisplayAlerts = True
    Exit Function
ErrorHandler:
    'Ha ocurrido un error al abrir la pagina, no existe
    ExisteRango = False
    Application.DisplayAlerts = False
    pag.Delete 'Borrar página de prueba
    Libro.Sheets("Busquedas").Range("A2").formula = ""  'Limpiar fórmula de prueba
    Application.DisplayAlerts = True
End Function

Function ExistePagina(nombrePag As String, Optional wb As Workbook) As Boolean
    Dim test As Worksheet
    If wb Is Nothing Then
        Set wb = ThisWorkbook 'Usar el libro actual
    End If
    On Error GoTo ErrorHandler
    Set test = wb.Sheets(nombrePag)
    ExistePagina = True
    Exit Function
ErrorHandler:
    'Ha ocurrido un error al abrir la pagina, no existe
    ExistePagina = False
End Function